## Mako configuration file
# Notification monitor
output=DP-3

# GLOBAL CONFIGURATION OPTIONS
max-history=100
sort=-time

# BINDING OPTIONS
on-button-left=dismiss
on-button-middle=dismiss-all
on-button-right=dismiss-all
on-touch=dismiss

# STYLE OPTIONS
font=JetBrains Mono 10
width=450
height=100
margin=20
padding=15
border-size=4
border-radius=4
icons=1
max-icon-size=48
icon-location=left
markup=1
actions=1
history=1
text-alignment=center
default-timeout=0
ignore-timeout=0
max-visible=5
layer=overlay
anchor=top-right

background-color=#151515
text-color=#ffffff
border-color=#1c1c1c
progress-color=over #89b4fa

[urgency=low]
border-color=#1c1c1c
default-timeout=4000

[urgency=normal]
border-color=#1c1c1c

[urgency=high]
border-color=#f38ba8
text-color=#f38ba8

[mode=notifications]
invisible=1
