{
  "network": {
    "interval": 5,
    "max-length": 20,
    "format-wifi": "{essid} 蟀ぅ",
    "format-ethernet": "Wired 蟀垁",
    "format-linked": "{ifname} (No IP) 蟀垁",
    "format-disconnected": "Disconnected 蟀き",
    "format-disabled": "Disabled 蟀ぎ",
    "tooltip-format": "{essid} via {gwaddr}",
    "on-click-right": "kitty --class wlctl -e wlctl",
  },
}
